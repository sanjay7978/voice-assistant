# Ollama local API
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_NUM_PREDICT=512

# Faster-Whisper model: tiny, base, small, medium, or large-v3
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Piper local executable and voice model paths
PIPER_EXECUTABLE=.venv/bin/piper
PIPER_VOICE_MODEL=models/en_US-lessac-medium.onnx
PIPER_VOICE_CONFIG=models/en_US-lessac-medium.onnx.json

# Audio settings
SAMPLE_RATE=16000
RECORD_SECONDS=5

# Timeout settings
STT_TIMEOUT_SECONDS=20
LLM_TIMEOUT_SECONDS=60
TTS_TIMEOUT_SECONDS=20

# Runtime folders
OUTPUT_DIR=outputs
LOG_DIR=logs
